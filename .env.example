# Base64-encoded contact email address.
# Decoded only at click time in the browser via atob() — never written to the DOM.
# Generate: node -e "process.stdout.write(Buffer.from('you@example.com').toString('base64'))"
# Copy the result as the value below, then save as .env.local (gitignored).
# In CI, set CONTACT_EMAIL_B64 as a secret and it is passed via the workflow.
PUBLIC_CONTACT_EMAIL_B64=
