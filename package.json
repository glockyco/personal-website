    "eslint": "^10.0.2",
    "eslint-plugin-svelte": "^3.15.0",
    "globals": "^17.4.0",
    "lefthook": "^2.1.2",
    "prettier": "^3.8.1",
    "prettier-plugin-svelte": "^3.5.0",
    "svelte": "^5.51.0",
